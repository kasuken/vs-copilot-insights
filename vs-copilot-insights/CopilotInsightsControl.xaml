<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:vs="http://schemas.microsoft.com/visualstudio/extensibility/2022/xaml"
              xmlns:colors="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0">
    <DataTemplate.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTextBrushKey}}" />
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#44808080" />
            <Setter Property="Background" Value="#16FFFFFF" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="SH" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="Margin" Value="2,6,0,6" />
        </Style>

        <Style x:Key="LBL" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="VAL" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="DIM" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Opacity" Value="0.45" />
            <Setter Property="FontSize" Value="11" />
        </Style>
    </DataTemplate.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="12,10,12,14"
                    TextElement.Foreground="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTextBrushKey}}">
            <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Center"
                        Margin="0,40,0,0">
                <TextBlock Text="Loading Copilot data..."
                           FontSize="12"
                           Opacity="0.6"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0" />
            </StackPanel>

            <Border Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                    Padding="14"
                    Margin="0,0,0,12"
                    Background="#22FF4444"
                    BorderBrush="#FFFF6B6B"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Something went wrong"
                               FontWeight="Bold"
                               Foreground="#FFFF6B6B"
                               FontSize="13" />
                    <TextBlock Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap"
                               Foreground="#FFFF6B6B"
                               Margin="0,6,0,0"
                               FontSize="12" />
                </StackPanel>
            </Border>

            <StackPanel Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}">

                <TextBlock Text="QUOTAS" Style="{StaticResource SH}" />
                <ItemsControl ItemsSource="{Binding Quotas}" Margin="0,0,0,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}">
                                <StackPanel TextElement.Foreground="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTextBrushKey}}">
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="Bold" FontSize="13" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusEmoji}" Style="{StaticResource DIM}" Margin="0,0,4,0" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding StatusLabel}" Style="{StaticResource DIM}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>

                                    <Border Visibility="{Binding ShowPremiumStats, Converter={StaticResource BoolToVis}}"
                                            HorizontalAlignment="Right"
                                            Background="#2A3A8DFF"
                                            CornerRadius="10"
                                            Padding="8,2"
                                            Margin="0,0,0,6">
                                        <TextBlock Text="{Binding PremiumRemainingPercent}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="White" />
                                    </Border>

                                    <ProgressBar Visibility="{Binding IsLimited, Converter={StaticResource BoolToVis}}"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding ProgressValue}"
                                                 Height="8"
                                                 Margin="0,0,0,8"
                                                 BorderThickness="0"
                                                 Background="#22000000" />

                                    <StackPanel Visibility="{Binding ShowPremiumStats, Converter={StaticResource BoolToVis}}"
                                                Margin="0,0,0,8">
                                        <TextBlock Text="Mood:" Style="{StaticResource DIM}" />
                                        <TextBlock Text="{Binding PremiumMood}" FontSize="13" FontWeight="SemiBold" Margin="0,2,0,6" />

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="Remaining:" Style="{StaticResource DIM}" />
                                            <TextBlock Grid.Column="1" Text="Used:" Style="{StaticResource DIM}" />
                                            <TextBlock Grid.Column="2" Text="Total:" Style="{StaticResource DIM}" />

                                            <TextBlock Grid.Column="0" Margin="0,18,0,0" Text="{Binding PremiumRemaining}" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" Margin="0,18,0,0" Text="{Binding PremiumUsed}" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="2" Margin="0,18,0,0" Text="{Binding PremiumTotal}" FontSize="13" FontWeight="SemiBold" />
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding ShowPremiumStats, Converter={StaticResource BoolToVis}}"
                                                Margin="0,10,0,0">
                                        <Border Height="1" Background="#22FFFFFF" Margin="0,0,0,10" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="To last until reset:" Style="{StaticResource DIM}" />
                                            <TextBlock Grid.Column="1" Text="{Binding PremiumAllowancePerDay}" FontWeight="SemiBold" />

                                            <TextBlock Grid.Column="0" Margin="0,22,0,0" Text="Reset in:" Style="{StaticResource DIM}" />
                                            <TextBlock Grid.Column="1" Margin="0,22,0,0" Text="{Binding PremiumResetIn}" FontWeight="SemiBold" />

                                            <TextBlock Grid.Column="0" Margin="0,44,0,0" Text="Reset date:" Style="{StaticResource DIM}" />
                                            <TextBlock Grid.Column="1" Margin="0,44,0,0" Text="{Binding PremiumResetDate}" FontWeight="SemiBold" />
                                        </Grid>

                                        <Border Height="1" Background="#22FFFFFF" Margin="0,12,0,10" />
                                        <TextBlock Text="Projection before reset" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Weekly average:" Style="{StaticResource DIM}" />
                                            <TextBlock Grid.Column="1" Text="{Binding PremiumWeeklyAverage}" FontWeight="SemiBold" />

                                            <TextBlock Grid.Column="0" Margin="0,22,0,0" Text="Work day average:" Style="{StaticResource DIM}" />
                                            <TextBlock Grid.Column="1" Margin="0,22,0,0" Text="{Binding PremiumWorkdayAverage}" FontWeight="SemiBold" />

                                            <TextBlock Grid.Column="0" Margin="0,44,0,0" Text="Work hour average:" Style="{StaticResource DIM}" />
                                            <TextBlock Grid.Column="1" Margin="0,44,0,0" Text="{Binding PremiumWorkhourAverage}" FontWeight="SemiBold" />
                                        </Grid>

                                        <Border Height="1" Background="#22FFFFFF" Margin="0,12,0,10" />
                                        <TextBlock Text="Daily capacity by model cost" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Efficient (0.33x):" Style="{StaticResource DIM}" />
                                            <TextBlock Grid.Column="1" Text="{Binding PremiumEfficientCapacity}" FontWeight="SemiBold" />

                                            <TextBlock Grid.Column="0" Margin="0,22,0,0" Text="Standard (1x):" Style="{StaticResource DIM}" />
                                            <TextBlock Grid.Column="1" Margin="0,22,0,0" Text="{Binding PremiumStandardCapacity}" FontWeight="SemiBold" />

                                            <TextBlock Grid.Column="0" Margin="0,44,0,0" Text="Advanced (3x):" Style="{StaticResource DIM}" />
                                            <TextBlock Grid.Column="1" Margin="0,44,0,0" Text="{Binding PremiumAdvancedCapacity}" FontWeight="SemiBold" />
                                        </Grid>

                                        <Border Height="1" Background="#22FFFFFF" Margin="0,12,0,8" />
                                        <TextBlock Text="{Binding PremiumOveragePolicy}" Style="{StaticResource DIM}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="RESET TIMING" Style="{StaticResource SH}" />
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="{Binding ResetCountdown}" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ResetDateDisplay}" Style="{StaticResource DIM}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <StackPanel Visibility="{Binding HasPacing, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="PACING GUIDANCE" Style="{StaticResource SH}" />
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="To stay within your quota:" Style="{StaticResource DIM}" Margin="0,0,0,10" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Daily" Style="{StaticResource LBL}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DailyValue}" Style="{StaticResource VAL}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Weekly" Style="{StaticResource LBL}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WeeklyValue}" Style="{StaticResource VAL}" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Workday" Style="{StaticResource LBL}" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding WorkdayValue}" Style="{StaticResource VAL}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>

            <TextBlock Text="PLAN DETAILS" Style="{StaticResource SH}" />
            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="7" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="7" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="7" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Plan" Style="{StaticResource LBL}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PlanValue}" Style="{StaticResource VAL}" FontWeight="SemiBold" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Chat" Style="{StaticResource LBL}" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ChatValue}" Style="{StaticResource VAL}" />
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="SKU" Style="{StaticResource LBL}" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SkuValue}" Style="{StaticResource VAL}" />
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Orgs" Style="{StaticResource LBL}" />
                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding OrgValue}" Style="{StaticResource VAL}" />
                </Grid>
            </Border>

            <Button Command="{Binding RefreshCommand}"
                    Padding="10,7"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Margin="0,4,0,0"
                    Background="#16FFFFFF"
                    BorderBrush="#44808080"
                    BorderThickness="1"
                    Foreground="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTextBrushKey}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Refresh" FontSize="12" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>
    </ScrollViewer>
</DataTemplate>